{
  "name": "parse-svg-path",
  "version": "0.2.0",
  "description": "svg path parser",
  "keywords": [
    "svg",
    "path",
    "parse",
    "parser"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm test",
    "build": "tsdown --dts --format esm,cjs --clean",
    "prepublishOnly": "npm run build",
    "test": "tsc && vitest run"
  },
  "devDependencies": {
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": "git://github.com/jkroso/parse-svg-path.git",
  "bugs": "https://github.com/jkroso/parse-svg-path/issues",
  "author": "Jake Rosoman",
  "license": "MIT"
}
